{
  "name": "gradpath-website",
  "version": "1.0.0",
  "description": "Secure Student Work Placement Management and Reporting System",
  "private": true,
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "test": "jest --config jest.config.js",
    "test:auth": "jest --config jest.config.js tests/auth/",
    "test:api": "jest --config jest.config.js tests/api/",
    "test:security": "jest --config jest.config.js tests/security/",
    "test:integration": "jest --config jest.config.js tests/integration/",
    "lint": "eslint backend/ --ext .js",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0",
    "morgan": "^1.10.0",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "xss-clean": "^0.1.4",
    "hpp": "^0.2.3"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0",
    "@types/jest": "^29.5.12"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
