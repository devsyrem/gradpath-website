# Environment Configuration — NEVER commit this file
NODE_ENV=development
PORT=3000

# Database
MONGODB_URI=mongodb://localhost:27017/gradpath
DB_NAME=gradpath

# JWT Secrets
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_MIN_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_RANDOM_SECRET_MIN_64_CHARS
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Encryption
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_KEY
ENCRYPTION_IV_LENGTH=16

# MFA
MFA_ISSUER=GradPath

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs
